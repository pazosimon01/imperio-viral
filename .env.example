# Apify API token — https://console.apify.com/settings/integrations
# IMPORTANT: rotar cualquier token que haya quedado en chats, logs o commits.
APIFY_TOKEN=

# OpenAI API key — para transcripción de reels con gpt-4o-transcribe.
# Crear en https://platform.openai.com/api-keys (requiere saldo).
# Costo: ~$0.006/min de audio (≈ $0.005 por reel típico).
OPENAI_API_KEY=

# Anthropic API key — para adaptación al español + anatomía con Claude Sonnet 4.6.
# Crear en https://console.anthropic.com/settings/keys (requiere saldo).
# Costo: ~$0.015 por reel.
ANTHROPIC_API_KEY=

# Postgres (Supabase) — Transaction pooler. La conexión directa es IPv6-only
# y casi ninguna red residencial Latam tiene IPv6, así que SIEMPRE usar pooler.
# Formato: postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres
# OJO: si tu password tiene caracteres especiales, URL-encodear (* → %2A, @ → %40, etc.)
DATABASE_URL=

# UUID del workspace activo. Después de aplicar migrations, crea uno con:
#   INSERT INTO workspaces (name) VALUES ('Mi equipo') RETURNING id;
# Y un nicho inicial:
#   INSERT INTO niches (workspace_id, name, slug) VALUES ('<ws-uuid>', 'General', 'general');
DEFAULT_WORKSPACE_ID=

# Supabase Storage — para thumbnails persistentes (las URLs de IG caducan en 24h).
# Settings → API → URL y service_role secret.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Proxy rotativo HTTP (opcional) — para analizar muchos perfiles sin que IG
# bloquee tu IP. Formato: http://usuario:password@host:puerto
# Sin proxy: ~30-50 perfiles antes de rate-limit. Con proxy: 1000+.
IG_PROXY_URL=

# ── Notion (opcional) — botón "Enviar a Notion" en el detalle del post ──────
# Envía la idea seleccionada a tu base de datos de Notion (ej. "Simon ideas").
#
# 1. Crea una integración interna en https://www.notion.so/my-integrations
#    (tipo "Internal", capability "Insert content" + "Read content").
#    Copia el "Internal Integration Secret" (empieza con "ntn_" o "secret_").
# 2. Abre tu tabla en Notion → menú "•••" → "Connections" / "Conexiones" →
#    conecta la integración que creaste (así le das acceso a esa DB).
# 3. NOTION_DATABASE_ID = el id de la DB (sale de la URL, con o sin guiones):
#    notion.so/…/<ESTE_ID>?v=…   — 32 caracteres hex.
NOTION_TOKEN=
NOTION_DATABASE_ID=
